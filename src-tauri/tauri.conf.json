{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Nestora",
  "version": "0.1.0",
  "identifier": "com.nestora.app",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "nuxt generate"
  },
  "app": {
    "windows": [
      {
        "title": "Nestora",
        "width": 420,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https: http: ws: wss: data: blob: tauri:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
